---
import Layout from '../layouts/Layout.astro';

const works = [
  { category: '電子零件', material: '黃銅', desc: '精密載盤・全孔位±0.02mm', photo: '/images/works/brass-charging-tray.jpg', photoAlt: '黃銅精密載盤 CNC 銑削加工 — 全孔位公差±0.02mm', href: '/works/brass-charging-tray' },
  { category: '電子零件', material: '黃銅（1.6mm 薄板）', desc: '超薄載板・平面度0.02mm', photo: '/images/works/brass-thin-plate.jpg', photoAlt: '黃銅超薄板 CNC 銑削加工 — 1.6mm 平面度0.02mm', href: '/works/brass-thin-plate' },
  { category: '工具機零件', material: '碳鋼 1018', desc: '油封座・內外徑切槽 Ra32', photo: '/images/works/machine-tool-seal-gland.jpg', photoAlt: '工具機油封座 CNC 車削加工 — 碳鋼內外徑密封溝槽 Ra32', href: '/works/machine-tool-seal-gland' },
  { category: '手工具零件', material: '純鈦 Gr.2', desc: '齒輪箱殼・雙向螺紋', photo: '/images/works/titanium-gear-case.jpg', photoAlt: '純鈦齒輪箱殼 CNC 車銑加工 — 鈦Gr.2 雙向螺紋', href: '/works/titanium-gear-case' },
  { category: '機械零件', material: '灰鑄鐵 EN-GJL-200', desc: '多楔皮帶輪車削加工', photo: '/images/works/cast-iron-pulley.jpg', photoAlt: '鑄鐵多楔皮帶輪 CNC 車削加工 — 灰鑄鐵 EN-GJL-200', href: '/works/cast-iron-pulley' },
  { category: '機械零件', material: '鑄鐵', desc: '滾珠螺桿支撐座銑削搪孔', photo: '/images/works/ballscrew-support-housing.jpg', photoAlt: '滾珠螺桿支撐座 CNC 銑削搪孔加工 — 鑄鐵', href: '/works/ballscrew-support-housing' },
  { category: '生存遊戲零件', material: '6061-T6 鋁合金', desc: '戰術護木 (M-LOK)', photo: '/images/airsoft-handguard.png', photoAlt: '戰術護木零件 — 6061-T6 鋁合金 CNC 加工' },
  { category: '機械零件', material: '鑄鐵 FCD250', desc: '減速機殼體加工' },
  { category: '機械零件', material: 'SCM440', desc: '精密軸類零件' },
  { category: '汽車零件', material: 'A356 鑄鋁', desc: '引擎本體加工' },
  { category: '汽車零件', material: 'S45C', desc: '傳動軸類' },
  { category: '自動化設備', material: 'A6061 鋁', desc: '機械手臂結構件' },
  { category: '自動化設備', material: '不鏽鋼 SUS304', desc: '輸送線零件' },
  { category: '精密治具', material: '工具鋼 SKD11', desc: '檢驗治具' },
  { category: '精密治具', material: 'A7075 鋁', desc: '組裝夾具' },
  { category: '半導體', material: '不鏽鋼 SUS316', desc: '真空腔體零件' },
  { category: '一般機械', material: '碳鋼 S20C', desc: '法蘭、底板' },
];

const categories = ['全部', ...new Set(works.map(w => w.category))];
---

<Layout
  title="實績案例｜CNC 加工服務客戶產業｜銨東股份有限公司"
  description="銨東股份有限公司服務產業包含機械、汽車、自動化設備、精密治具、半導體等。依客戶 NDA 規範，僅展示加工件代表作，實際合作案例請洽詢。"
  active="works"
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">首頁</a> ／ 實績案例</div>
      <h1>實績案例</h1>
      <p style="margin-top: 12px; color: rgba(255,255,255,0.85);">服務多元產業，累積數百種圖號加工經驗</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">加工件展示</h2>
      <p class="section-sub">依產業類別精選代表作，長期供應美商工具機大廠與國際氣動工具品牌，實際合作案例請來電洽詢</p>

      <div class="grid-4">
        {works.map(w => {
          const card = (
            <>
              <div class="spec-img" style="aspect-ratio: 1/1; overflow: hidden; padding: 0;">
                {w.photo ? (
                  <img src={w.photo} alt={w.photoAlt} loading="lazy" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                ) : (
                  <span>📷 加工件照</span>
                )}
              </div>
              <div style="padding: 16px;">
                <div style="font-size: 12px; color: var(--primary); font-weight: 700; margin-bottom: 4px;">{w.category}</div>
                <div style="font-size: 15px; font-weight: 600; color: var(--gray-900); margin-bottom: 4px;">{w.desc}</div>
                <div style="font-size: 13px; color: var(--gray-600);">{w.material}</div>
                {w.href && <div style="font-size: 13px; color: var(--primary); font-weight: 600; margin-top: 8px;">查看案例 →</div>}
              </div>
            </>
          );
          return w.href
            ? <a href={w.href} class="spec-card" style="display: block; text-decoration: none;">{card}</a>
            : <div class="spec-card">{card}</div>;
        })}
      </div>

      <p style="text-align: center; color: var(--gray-600); margin-top: 48px; font-size: 14px; max-width: 700px; margin-left: auto; margin-right: auto; line-height: 1.8;">
        ※ 出於與客戶簽署的保密協議，本網站僅展示加工件類型示意，不公開客戶名稱與具體圖面。<br />
        如需評估合作，歡迎來電索取相關產業實作參考案例。
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">服務產業範圍</h2>
      <div class="grid-4">
        <div class="card"><div class="card-icon">🏭</div><h3>機械製造</h3><p>減速機、齒輪箱、傳動件</p></div>
        <div class="card"><div class="card-icon">🚗</div><h3>汽車產業</h3><p>引擎件、傳動件、底盤件</p></div>
        <div class="card"><div class="card-icon">🤖</div><h3>自動化設備</h3><p>機械手臂、輸送、夾治具</p></div>
        <div class="card"><div class="card-icon">⚗️</div><h3>半導體</h3><p>真空腔體、晶圓夾具</p></div>
        <div class="card"><div class="card-icon">🔬</div><h3>精密治具</h3><p>檢驗治具、組裝夾具</p></div>
        <div class="card"><div class="card-icon">⚙️</div><h3>一般機械</h3><p>法蘭、底板、軸類</p></div>
      </div>
    </div>
  </section>

  <section class="section cta">
    <div class="container">
      <h2>有相關產業合作經驗</h2>
      <p>歡迎傳圖面評估，我們會以最快速度回覆估價</p>
      <a href="/contact" class="btn btn-primary btn-lg">立即詢價</a>
    </div>
  </section>
</Layout>
