---
import Layout from '../../layouts/Layout.astro';

const FORMSPREE_ENDPOINT = 'https://formspree.io/f/YOUR_FORM_ID';
---

<Layout
  title="Contact &amp; Request a Quote | AnDong Co., Ltd. | CNC Machining Inquiry"
  description="Contact AnDong Co., Ltd. for CNC machining inquiries. Taichung, Taiwan. Tel: +886-4-24965670, Email: andong@adcnc.com.tw. Send your drawing, specs, and quantity — we respond with a quote the same day."
  active="contact"
  lang="en"
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/en">Home</a> / Contact</div>
      <h1>Contact &amp; Quote</h1>
      <p style="margin-top: 12px; color: rgba(255,255,255,0.85);">Send your drawing, specs, and quantity — we'll quote the same day</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: 1100px;">
      <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 56px;" class="contact-row">
        <!-- Quote form -->
        <div>
          <h2 style="font-size: clamp(24px, 2.5vw, 32px); color: var(--gray-900); margin-bottom: 8px; font-weight: 700;">Request a Quote</h2>
          <p style="color: var(--gray-600); margin-bottom: 32px;">Fill in the form below; we'll respond within 1 business day. You can also call +886-4-24965670 or contact us on LINE.</p>

          <form action={FORMSPREE_ENDPOINT} method="POST" enctype="multipart/form-data">
            <div class="form-row">
              <div class="form-field">
                <label>Contact Name <span class="form-required">*</span></label>
                <input type="text" name="name" required />
              </div>
              <div class="form-field">
                <label>Company</label>
                <input type="text" name="company" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <label>Phone <span class="form-required">*</span></label>
                <input type="tel" name="phone" required />
              </div>
              <div class="form-field">
                <label>E-mail <span class="form-required">*</span></label>
                <input type="email" name="email" required />
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <label>Estimated Quantity</label>
                <input type="text" name="quantity" placeholder="e.g., 50 pcs / 1,000 pcs per month" />
              </div>
              <div class="form-field">
                <label>Required Lead Time</label>
                <input type="text" name="deadline" placeholder="e.g., 2 weeks / urgent" />
              </div>
            </div>

            <div class="form-field" style="margin-bottom: 16px;">
              <label>Inquiry / Drawing Description <span class="form-required">*</span></label>
              <textarea name="message" required placeholder="Please describe the part application, material, expected machining operations, and any special requirements…"></textarea>
            </div>

            <div class="form-field" style="margin-bottom: 24px;">
              <label>Upload Drawings (PDF / JPG / DWG / STEP, multiple files OK)</label>
              <input type="file" name="attachment" multiple accept=".pdf,.jpg,.jpeg,.png,.dwg,.dxf,.step,.stp,.iges" />
              <p class="form-help">Max 10MB per file; for larger files please email andong@adcnc.com.tw</p>
            </div>

            <button type="submit" class="btn btn-primary btn-lg" style="width: 100%;">Submit Inquiry</button>
            <p class="form-help" style="text-align: center; margin-top: 12px;">An auto-reply will be sent after submission — please also check your spam folder.</p>
          </form>
        </div>

        <!-- Contact info -->
        <div>
          <h2 style="font-size: clamp(24px, 2.5vw, 32px); color: var(--gray-900); margin-bottom: 24px; font-weight: 700;">Contact Information</h2>

          <div class="card" style="padding: 28px; margin-bottom: 16px;">
            <div style="display: flex; align-items: start; gap: 16px;">
              <div style="font-size: 28px;">📞</div>
              <div>
                <div style="font-size: 13px; color: var(--gray-600); margin-bottom: 4px;">Phone</div>
                <a href="tel:+886424965670" style="font-size: 22px; font-weight: 700; color: var(--primary);">+886-4-24965670</a>
              </div>
            </div>
          </div>

          <div class="card" style="padding: 28px; margin-bottom: 16px;">
            <div style="display: flex; align-items: start; gap: 16px;">
              <div style="font-size: 28px;">💬</div>
              <div style="flex: 1;">
                <div style="font-size: 13px; color: var(--gray-600); margin-bottom: 4px;">LINE Official Account</div>
                <a href="https://line.me/R/ti/p/@714dgtve" target="_blank" rel="noopener" style="font-size: 18px; font-weight: 700; color: #06c755;">@714dgtve</a>
                <div style="margin-top: 16px; max-width: 200px; background: #fff; border: 1px solid var(--gray-200); border-radius: 8px; padding: 12px;">
                  <img src="/images/line-qr.png" alt="AnDong Co., Ltd. LINE Official Account QR Code" style="width: 100%; display: block;" />
                  <p style="text-align: center; font-size: 12px; color: var(--gray-600); margin-top: 8px;">Scan with your phone to add</p>
                </div>
              </div>
            </div>
          </div>

          <div class="card" style="padding: 28px; margin-bottom: 16px;">
            <div style="display: flex; align-items: start; gap: 16px;">
              <div style="font-size: 28px;">✉️</div>
              <div>
                <div style="font-size: 13px; color: var(--gray-600); margin-bottom: 4px;">Email</div>
                <a href="mailto:andong@adcnc.com.tw" style="font-size: 16px; font-weight: 600; color: var(--gray-900);">andong@adcnc.com.tw</a>
              </div>
            </div>
          </div>

          <div class="card" style="padding: 28px; margin-bottom: 16px;">
            <div style="display: flex; align-items: start; gap: 16px;">
              <div style="font-size: 28px;">📍</div>
              <div>
                <div style="font-size: 13px; color: var(--gray-600); margin-bottom: 4px;">Address</div>
                <div style="font-weight: 600; line-height: 1.6;">No. 22, Lane 29, Chenggong Rd.,<br />Taiping Dist., Taichung City 411, Taiwan</div>
                <div style="font-size: 13px; color: var(--gray-600); margin-top: 4px;">Fax: +886-4-24966591</div>
              </div>
            </div>
          </div>

          <div class="card" style="padding: 28px;">
            <div style="display: flex; align-items: start; gap: 16px;">
              <div style="font-size: 28px;">🕐</div>
              <div>
                <div style="font-size: 13px; color: var(--gray-600); margin-bottom: 4px;">Business Hours</div>
                <div style="font-weight: 600;">Monday – Saturday</div>
                <div>08:00 – 17:00 (GMT+8)</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Google Maps -->
      <div style="margin-top: 64px;">
        <h2 style="font-size: clamp(24px, 2.5vw, 32px); color: var(--gray-900); margin-bottom: 24px; font-weight: 700; text-align: center;">Find Us</h2>
        <div style="aspect-ratio: 16/7; border-radius: 16px; overflow: hidden; border: 1px solid var(--gray-200);">
          <iframe
            src="https://maps.google.com/maps?q=No.+22,+Lane+29,+Chenggong+Rd.,+Taiping+Dist.,+Taichung+City,+Taiwan&hl=en&z=17&output=embed"
            width="100%"
            height="100%"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="AnDong Co., Ltd. Location Map"
            allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </section>

  <style>
    @media (max-width: 900px) {
      .contact-row { grid-template-columns: 1fr !important; gap: 40px !important; }
    }
  </style>
</Layout>
