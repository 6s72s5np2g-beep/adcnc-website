---
import Layout from '../../../layouts/Layout.astro';

const specs = [
  { label: 'Part Type', value: 'Poly-V pulley for single-cylinder air compressor' },
  { label: 'Material', value: 'EN-GJL-200 grey cast iron (equiv. FC200)' },
  { label: 'Size / Weight', value: 'OD Ø186.5 mm / approx. 2.8 kg' },
  { label: 'Groove Profile', value: 'PK multi-rib grooves (ISO 9982)' },
  { label: 'Process', value: 'CNC turning' },
  { label: 'Blank', value: 'Customer-supplied casting (cataphoresis coated)' },
  { label: 'Application', value: 'Agricultural machinery, air compressors' },
];
---

<Layout
  title="Cast Iron Poly-V Pulley CNC Turning Case Study | EN-GJL-200 Grey Iron | AnDong Co., Ltd."
  description="CNC turning case study: EN-GJL-200 grey cast iron Poly-V pulley, Ø186.5mm PK multi-rib grooves per ISO 9982, machined from customer-supplied castings. Precision CNC machining in Taichung, Taiwan."
  keywords="cast iron pulley machining,poly-v pulley,multi-rib pulley,grey iron turning,FC200 machining,casting machining,CNC turning Taiwan,Taichung CNC"
  active="works"
  lang="en"
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/en">Home</a> / <a href="/en/works">Industries</a> / Cast Iron Poly-V Pulley</div>
      <h1>Cast Iron Poly-V Pulley — CNC Turning</h1>
      <p style="margin-top: 12px; color: rgba(255,255,255,0.85);">EN-GJL-200 grey iron · PK multi-rib groove form turning · customer-supplied casting</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px; align-items: start;">
        <div>
          <img
            src="/images/works/cast-iron-pulley.jpg"
            alt="Cast iron Poly-V pulley CNC turning — EN-GJL-200 grey iron multi-rib pulley, finish turned"
            loading="eager"
            style="width: 100%; border-radius: 8px; box-shadow: 0 4px 16px rgba(0,0,0,0.12);"
          />
          <p style="font-size: 13px; color: var(--gray-600); margin-top: 10px;">Finish-turned part: PK grooves on OD and finish-bored hub, with as-cast coated spokes</p>
        </div>
        <div>
          <h2 class="section-title" style="text-align: left;">Specifications</h2>
          <table style="width: 100%; border-collapse: collapse; font-size: 15px;">
            {specs.map(s => (
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px 12px 10px 0; color: var(--gray-600); white-space: nowrap; vertical-align: top;">{s.label}</td>
                <td style="padding: 10px 0; color: var(--gray-900); font-weight: 500;">{s.value}</td>
              </tr>
            ))}
          </table>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Machining Highlights</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px;">
        <div class="card">
          <div class="card-icon">🔩</div>
          <h3>Multi-Rib Form Turning</h3>
          <p>PK grooves are form-turned with profile tooling; groove geometry and pitch are controlled per ISO 9982 to ensure belt seating and drive efficiency.</p>
        </div>
        <div class="card">
          <div class="card-icon">🎯</div>
          <h3>Casting Datum Setup</h3>
          <p>Customer-supplied castings are located on as-cast datum faces, controlling concentricity between machined and cast surfaces to avoid wall-thickness deviation.</p>
        </div>
        <div class="card">
          <div class="card-icon">🛠️</div>
          <h3>Cast Iron Cutting Control</h3>
          <p>Tool-wear and chip management for interrupted cuts in grey iron, keeping dimensions stable across production batches.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta">
    <div class="container">
      <h2>Have a similar casting or pulley project?</h2>
      <p>Send us your drawing — we'll respond with a quote as fast as possible</p>
      <a href="/en/contact" class="btn btn-primary btn-lg">Request a Quote</a>
      <p style="margin-top: 16px;"><a href="/en/works" style="color: rgba(255,255,255,0.8);">← Back to Industries</a></p>
    </div>
  </section>
</Layout>
