---
import Layout from '../../layouts/Layout.astro';

const works = [
  { category: 'Electronics', material: 'Brass', desc: 'Precision carrier tray · holes ±0.02mm', photo: '/images/works/brass-charging-tray.jpg', photoAlt: 'Brass precision carrier tray CNC milling — all holes ±0.02mm', href: '/en/works/brass-charging-tray' },
  { category: 'Electronics', material: 'Brass (1.6mm plate)', desc: 'Ultra-thin carrier plate · flatness 0.02mm', photo: '/images/works/brass-thin-plate.jpg', photoAlt: 'Brass ultra-thin plate CNC milling — 1.6mm flatness 0.02mm', href: '/en/works/brass-thin-plate' },
  { category: 'Machine Tools', material: 'Carbon Steel 1018', desc: 'Seal gland · ID/OD grooves Ra32', photo: '/images/works/machine-tool-seal-gland.jpg', photoAlt: 'Machine-tool rod seal gland CNC turning — carbon steel ID/OD grooves Ra32', href: '/en/works/machine-tool-seal-gland' },
  { category: 'Hand Tools', material: 'Titanium Gr.2', desc: 'Gear case · dual threads', photo: '/images/works/titanium-gear-case.jpg', photoAlt: 'Titanium gear case CNC turn-mill — Ti Gr.2 dual threads', href: '/en/works/titanium-gear-case' },
  { category: 'Machinery', material: 'EN-GJL-200 Grey Cast Iron', desc: 'Poly-V pulley CNC turning', photo: '/images/works/cast-iron-pulley.jpg', photoAlt: 'Cast iron Poly-V pulley CNC turning — EN-GJL-200 grey iron', href: '/en/works/cast-iron-pulley' },
  { category: 'Machinery', material: 'Cast Iron', desc: 'Ball screw support housing milling & boring', photo: '/images/works/ballscrew-support-housing.jpg', photoAlt: 'Ball screw support housing CNC milling and boring — cast iron', href: '/en/works/ballscrew-support-housing' },
  { category: 'Airsoft / Tactical Gear', material: '6061-T6 Aluminum Alloy', desc: 'Tactical handguard (M-LOK)', photo: '/images/airsoft-handguard.png', photoAlt: 'Airsoft tactical handguard — 6061-T6 aluminum CNC machined' },
  { category: 'Machinery', material: 'Ductile Iron FCD250', desc: 'Reduction gear housing' },
  { category: 'Machinery', material: 'SCM440', desc: 'Precision shaft' },
  { category: 'Automotive', material: 'A356 Cast Aluminum', desc: 'Engine body machining' },
  { category: 'Automotive', material: 'S45C', desc: 'Drive shaft' },
  { category: 'Factory Automation', material: 'A6061 Aluminum', desc: 'Robotic arm structural part' },
  { category: 'Factory Automation', material: 'SUS304 Stainless', desc: 'Conveyor line components' },
  { category: 'Precision Tooling', material: 'SKD11 Tool Steel', desc: 'Inspection fixture' },
  { category: 'Precision Tooling', material: 'A7075 Aluminum', desc: 'Assembly jig' },
  { category: 'Semiconductor', material: 'SUS316 Stainless', desc: 'Vacuum chamber component' },
  { category: 'General Industrial', material: 'S20C Carbon Steel', desc: 'Flange, base plate' },
];
---

<Layout
  title="Industries Served | CNC Machining Customer Case Studies | AnDong Co., Ltd."
  description="AnDong serves the machinery, automotive, factory automation, precision tooling, and semiconductor industries. Per customer NDAs, only representative part types are shown. Contact us for relevant case studies."
  active="works"
  lang="en"
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/en">Home</a> / Industries</div>
      <h1>Industries Served</h1>
      <p style="margin-top: 12px; color: rgba(255,255,255,0.85);">Serving diverse industries, with hundreds of part numbers in production</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Sample Parts</h2>
      <p class="section-sub">Selected representative parts by industry. A long-term supplier to a US machine-tool OEM and international pneumatic-tool brands. Contact us for relevant case studies.</p>

      <div class="grid-4">
        {works.map(w => {
          const card = (
            <>
              <div class="spec-img" style="aspect-ratio: 1/1; overflow: hidden; padding: 0;">
                {w.photo ? (
                  <img src={w.photo} alt={w.photoAlt} loading="lazy" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                ) : (
                  <span>📷 Part Photo</span>
                )}
              </div>
              <div style="padding: 16px;">
                <div style="font-size: 12px; color: var(--primary); font-weight: 700; margin-bottom: 4px;">{w.category}</div>
                <div style="font-size: 15px; font-weight: 600; color: var(--gray-900); margin-bottom: 4px;">{w.desc}</div>
                <div style="font-size: 13px; color: var(--gray-600);">{w.material}</div>
                {w.href && <div style="font-size: 13px; color: var(--primary); font-weight: 600; margin-top: 8px;">View case study →</div>}
              </div>
            </>
          );
          return w.href
            ? <a href={w.href} class="spec-card" style="display: block; text-decoration: none;">{card}</a>
            : <div class="spec-card">{card}</div>;
        })}
      </div>

      <p style="text-align: center; color: var(--gray-600); margin-top: 48px; font-size: 14px; max-width: 700px; margin-left: auto; margin-right: auto; line-height: 1.8;">
        * Per NDAs with our customers, only representative part types are shown — customer names and drawings are not disclosed.<br />
        For partnership evaluation, contact us to request relevant case references for your industry.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Industries We Serve</h2>
      <div class="grid-4">
        <div class="card"><div class="card-icon">🏭</div><h3>Machinery</h3><p>Reducers, gearboxes, drive components</p></div>
        <div class="card"><div class="card-icon">🚗</div><h3>Automotive</h3><p>Engine parts, drivetrain, chassis components</p></div>
        <div class="card"><div class="card-icon">🤖</div><h3>Factory Automation</h3><p>Robotic arms, conveyors, jigs and fixtures</p></div>
        <div class="card"><div class="card-icon">⚗️</div><h3>Semiconductor</h3><p>Vacuum chambers, wafer fixtures</p></div>
        <div class="card"><div class="card-icon">🔬</div><h3>Precision Tooling</h3><p>Inspection fixtures, assembly jigs</p></div>
        <div class="card"><div class="card-icon">⚙️</div><h3>General Industrial</h3><p>Flanges, base plates, shafts</p></div>
      </div>
    </div>
  </section>

  <section class="section cta">
    <div class="container">
      <h2>Have a project in these industries?</h2>
      <p>Send us your drawing — we'll respond with a quote as fast as possible</p>
      <a href="/en/contact" class="btn btn-primary btn-lg">Request a Quote</a>
    </div>
  </section>
</Layout>
