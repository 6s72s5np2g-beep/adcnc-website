---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="AnDong Co., Ltd. | Precision CNC Machining in Taichung, Taiwan | Turn-Mill, 5-Axis, 3/4-Axis Milling"
  description="Taichung-based precision CNC machining manufacturer with 20+ years of experience. Turn-mill, 5-axis (3+2), 3/4-axis milling, CNC turning of aluminum, steel, stainless steel, and cast iron — from prototype to volume production. Same-day quote with drawings."
  active="home"
  lang="en"
>
  <section class="hero">
    <div class="hero-inner">
      <h1>Precision Parts, On-Time Delivery</h1>
      <p class="hero-sub">Taichung, Taiwan · 20+ years of precision CNC machining expertise. Specialized in turn-mill, 5-axis, and 3/4-axis milling.<br />End-to-end manufacturing from raw material to finished part.</p>
      <div class="hero-actions">
        <a href="/en/contact" class="btn btn-primary">Request a Quote</a>
        <a href="/en/services" class="btn btn-ghost">Our Services</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Machining Services</h2>
      <p class="section-sub">Full-spectrum CNC capabilities, from low-volume prototyping to mass production</p>
      <div class="grid-6">
        <a href="/en/services#turn-mill" class="card"><div class="card-icon">⚙</div><h3>Turn-Mill Machining</h3><p>Single-setup turning &amp; milling for higher precision and efficiency</p></a>
        <a href="/en/services#5-axis" class="card"><div class="card-icon">🔧</div><h3>5-Axis Machining</h3><p>3+2 positioning, multi-face machining in one setup</p></a>
        <a href="/en/services#mill-3-4" class="card"><div class="card-icon">📐</div><h3>3/4-Axis Milling</h3><p>Precision molds, jigs, fixtures, structural components</p></a>
        <a href="/en/services#turning" class="card"><div class="card-icon">🔩</div><h3>CNC Turning</h3><p>Shafts, sleeves, connectors — production runs</p></a>
        <a href="/en/services#cast" class="card"><div class="card-icon">🏗️</div><h3>Cast Aluminum / Iron</h3><p>FCD250, A356 and other large-part machining</p></a>
        <a href="/en/services#stainless" class="card"><div class="card-icon">⚒️</div><h3>Stainless / Steel / Plate</h3><p>SUS304, S45C, A7075 — full material range</p></a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Why AnDong</h2>
      <div class="grid-3">
        <div class="feature">
          <h3>20+ Years of Experience</h3>
          <p>Hundreds of part numbers delivered across machinery, automotive, factory automation, and precision tooling industries.</p>
        </div>
        <div class="feature">
          <h3>Real-Time Production Monitoring</h3>
          <p>Networked machines provide live progress tracking — transparent lead times and full traceability for every order.</p>
        </div>
        <div class="feature">
          <h3>One-Stop Manufacturing</h3>
          <p>From material sourcing and machining to heat treatment, surface finishing, inspection, and shipment — integrated to shorten lead times.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta">
    <div class="container">
      <h2>Have a drawing? Get a quote today.</h2>
      <p>Send your drawing, specs, and quantity — we'll respond with a quote the same day.</p>
      <a href="/en/contact" class="btn btn-primary btn-lg">Contact Us</a>
    </div>
  </section>
</Layout>
