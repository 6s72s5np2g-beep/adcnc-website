---
import Layout from '../../layouts/Layout.astro';

const specs = [
  { label: '產品類型', value: '單缸空壓機用多楔皮帶輪（Poly-V）' },
  { label: '材質', value: 'EN-GJL-200 灰鑄鐵（相當於 FC200）' },
  { label: '尺寸／重量', value: '外徑 Ø186.5 mm／約 2.8 kg' },
  { label: '槽形規範', value: 'PK 多楔槽（ISO 9982）' },
  { label: '加工方式', value: 'CNC 車床車削' },
  { label: '毛坯', value: '客戶供料鑄件（卡泳防鏽塗裝）' },
  { label: '應用領域', value: '農業機械、空壓機' },
];
---

<Layout
  title="鑄鐵多楔皮帶輪 CNC 車削加工案例｜灰鑄鐵 EN-GJL-200｜銨東股份有限公司"
  description="灰鑄鐵 EN-GJL-200 多楔皮帶輪 CNC 車床加工案例：Ø186.5mm PK 多楔槽（ISO 9982）成形車削、客供鑄件加工，應用於農業機械空壓機。台中太平 CNC 加工廠銨東。"
  keywords="鑄鐵皮帶輪加工,多楔皮帶輪,Poly-V皮帶輪,灰鑄鐵車削,FC200加工,鑄件加工,CNC車床加工,台中CNC,皮帶輪車削"
  active="works"
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">首頁</a> ／ <a href="/works">實績案例</a> ／ 鑄鐵多楔皮帶輪</div>
      <h1>鑄鐵多楔皮帶輪 CNC 車削加工</h1>
      <p style="margin-top: 12px; color: rgba(255,255,255,0.85);">灰鑄鐵 EN-GJL-200・PK 多楔槽成形車削・客供鑄件</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px; align-items: start;">
        <div>
          <img
            src="/images/works/cast-iron-pulley.jpg"
            alt="鑄鐵多楔皮帶輪 CNC 車削加工 — 灰鑄鐵 EN-GJL-200 多楔槽（Poly-V）車削完成品"
            loading="eager"
            style="width: 100%; border-radius: 8px; box-shadow: 0 4px 16px rgba(0,0,0,0.12);"
          />
          <p style="font-size: 13px; color: var(--gray-600); margin-top: 10px;">多楔槽車削完成品：外圓 PK 槽與內孔精車面，輪輻保留鑄造塗裝原面</p>
        </div>
        <div>
          <h2 class="section-title" style="text-align: left;">加工規格</h2>
          <table style="width: 100%; border-collapse: collapse; font-size: 15px;">
            {specs.map(s => (
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px 12px 10px 0; color: var(--gray-600); white-space: nowrap; vertical-align: top;">{s.label}</td>
                <td style="padding: 10px 0; color: var(--gray-900); font-weight: 500;">{s.value}</td>
              </tr>
            ))}
          </table>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">加工重點</h2>
      <div class="grid-3" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px;">
        <div class="card">
          <div class="card-icon">🔩</div>
          <h3>多楔槽成形車削</h3>
          <p>PK 槽以成形刀車削，槽形輪廓與槽距依 ISO 9982 皮帶輪規範管控，確保皮帶貼合度與傳動效率。</p>
        </div>
        <div class="card">
          <div class="card-icon">🎯</div>
          <h3>鑄件基準找正</h3>
          <p>客供鑄件以鑄造基準面夾持找正，控制車削面與鑄面的同心度，避免壁厚偏差。</p>
        </div>
        <div class="card">
          <div class="card-icon">🛠️</div>
          <h3>鑄鐵切削管理</h3>
          <p>灰鑄鐵斷續切削之刀具磨耗管理與排屑控制，維持批量加工的尺寸穩定。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta">
    <div class="container">
      <h2>有類似的鑄件、皮帶輪加工需求？</h2>
      <p>歡迎傳圖面評估，我們會以最快速度回覆估價</p>
      <a href="/contact" class="btn btn-primary btn-lg">立即詢價</a>
      <p style="margin-top: 16px;"><a href="/works" style="color: rgba(255,255,255,0.8);">← 回實績案例</a></p>
    </div>
  </section>
</Layout>
