---
import Layout from '../../layouts/Layout.astro';

const specs = [
  { label: '產品類型', value: '黃銅精密零件載盤（多槽定位）' },
  { label: '材質', value: '黃銅（Brass）' },
  { label: '加工精度', value: '全孔位公差 ±0.02 mm' },
  { label: '表面處理', value: '光澤鍍處理（抗氧化・外觀質感）' },
  { label: '加工方式', value: 'CNC 銑削' },
  { label: '應用領域', value: '電子產業（連接器、充電相關精密載具）' },
];
---

<Layout
  title="黃銅精密載盤 CNC 銑削加工案例｜全孔位公差±0.02mm｜銨東股份有限公司"
  description="黃銅精密零件載盤 CNC 銑削加工案例：數十處孔位公差全數控制在 ±0.02mm，光澤鍍表面處理，應用於電子連接器、充電相關精密定位載具。台中太平 CNC 銅件加工廠銨東。"
  keywords="黃銅加工,銅件加工,黃銅銑削,精密載盤,治具加工,電子零件加工,孔位公差,CNC銑削,台中CNC,銅料加工"
  active="works"
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">首頁</a> ／ <a href="/works">實績案例</a> ／ 黃銅精密載盤</div>
      <h1>黃銅精密載盤 CNC 銑削加工</h1>
      <p style="margin-top: 12px; color: rgba(255,255,255,0.85);">黃銅・全孔位公差 ±0.02mm・光澤鍍處理</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px; align-items: start;">
        <div>
          <img
            src="/images/works/brass-charging-tray.jpg"
            alt="黃銅精密零件載盤 CNC 銑削加工 — 多槽定位、全孔位公差±0.02mm、光澤鍍表面"
            loading="eager"
            style="width: 100%; border-radius: 8px; box-shadow: 0 4px 16px rgba(0,0,0,0.12);"
          />
          <p style="font-size: 13px; color: var(--gray-600); margin-top: 10px;">一體銑削成形的多槽定位載盤，數十處孔位公差全數收斂於 ±0.02mm</p>
        </div>
        <div>
          <h2 class="section-title" style="text-align: left;">加工規格</h2>
          <table style="width: 100%; border-collapse: collapse; font-size: 15px;">
            {specs.map(s => (
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px 12px 10px 0; color: var(--gray-600); white-space: nowrap; vertical-align: top;">{s.label}</td>
                <td style="padding: 10px 0; color: var(--gray-900); font-weight: 500;">{s.value}</td>
              </tr>
            ))}
          </table>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">加工重點</h2>
      <div class="grid-3" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px;">
        <div class="card">
          <div class="card-icon">🎯</div>
          <h3>全孔位 ±0.02mm</h3>
          <p>數十處孔位、槽位的位置度一次銑削到位，孔位公差全數收斂於 ±0.02mm，確保載盤的定位精度與零件互換性。</p>
        </div>
        <div class="card">
          <div class="card-icon">✨</div>
          <h3>光澤鍍面處理</h3>
          <p>黃銅本體經光澤鍍處理，兼顧抗氧化防護與外觀質感，適合長期使用的精密電子載具。</p>
        </div>
        <div class="card">
          <div class="card-icon">🔩</div>
          <h3>黃銅切削管理</h3>
          <p>黃銅延展性高、孔緣易生毛邊，以適當刀具與切削參數管控孔緣光潔度與去毛邊品質。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta">
    <div class="container">
      <h2>有黃銅、銅件或精密載盤加工需求？</h2>
      <p>歡迎傳圖面評估，我們會以最快速度回覆估價</p>
      <a href="/contact" class="btn btn-primary btn-lg">立即詢價</a>
      <p style="margin-top: 16px;"><a href="/works" style="color: rgba(255,255,255,0.8);">← 回實績案例</a></p>
    </div>
  </section>
</Layout>
